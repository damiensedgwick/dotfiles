{
  "buffer_font_family": "ComicShannsMono Nerd Font Mono",
  "buffer_font_size": 17,
  "close_on_file_delete": true,
  "confirm_quit": true,
  "collaboration_panel": {
    "button": false,
  },
  "cursor_blink": false,
  "disable_ai": true,
  "edit_predictions": {
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
    "enabled_in_text_threads": false,
  },
  "git_panel": {
    "default_width": 300,
    "dock": "right",
  },
  "notification_panel": {
    "button": false,
  },
  "outline_panel": {
    "button": false,
  },
  "project_panel": {
    "default_width": 300,
    "dock": "right",
  },
  "restore_on_startup": "empty_tab",
  "ui_font_family": "ComicShannsMono Nerd Font Mono",
  "ui_font_size": 17,
}
